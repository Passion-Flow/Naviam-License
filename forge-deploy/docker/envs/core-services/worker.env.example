# ------------------------------------------------------------------
# Optional: forge-worker only knobs. Copy as worker.env.
# ------------------------------------------------------------------
# Celery worker concurrency. 0 means use the SDK default (CPU count).
CELERY_WORKER_CONCURRENCY=0
# Soft time limit per task (seconds).
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
