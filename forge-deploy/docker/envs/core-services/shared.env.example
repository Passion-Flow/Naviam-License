# ------------------------------------------------------------------
# Optional: knobs shared by forge-api / forge-worker / forge-scheduler.
# Activate only when you need to override defaults from .env.
# Copy this file as shared.env (drop the .example suffix).
# ------------------------------------------------------------------
# Override default log destination (stdout is default).
LOG_FILE_PATH=
# Force the runtime to fail fast when a non-critical dependency is missing.
STRICT_STARTUP=false
