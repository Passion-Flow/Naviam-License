# ------------------------------------------------------------------
# Optional: forge-api only knobs. Activate when overriding defaults.
# Copy this file as api.env.
# ------------------------------------------------------------------
# Gunicorn workers (default chosen by image entrypoint).
API_WORKER_AMOUNT=
# Request timeout (seconds).
API_REQUEST_TIMEOUT=60
# CORS allow-list (comma-separated origins, "*" for any).
API_CORS_ALLOW_ORIGINS=*
