# ------------------------------------------------------------------
# Azure Blob Storage. Activate when OBJECT_STORAGE_TYPE=azure-blob.
# Copy as azure-blob.env.
# ------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=https://<account>.blob.core.windows.net
OBJECT_STORAGE_ACCESS_KEY_ID=<account>
OBJECT_STORAGE_ACCESS_KEY_SECRET=#REPLACE_ME#
# AzureCloud / AzureChinaCloud — pick endpoint suffix accordingly.
OBJECT_STORAGE_AZURE_ENDPOINT_SUFFIX=core.windows.net
OBJECT_STORAGE_AZURE_USE_MANAGED_IDENTITY=false
