# ------------------------------------------------------------------
# Local Object Storage — filesystem or self-hosted MinIO.
# Activate when OBJECT_STORAGE_TYPE=local. Copy as local.env.
# ------------------------------------------------------------------
# The local mode support: filesystem, minio
OBJECT_STORAGE_LOCAL_MODE=minio

# ─── filesystem mode (pod-mounted PV) ───
OBJECT_STORAGE_LOCAL_PATH=/var/lib/forge/storage

# ─── minio mode (bundled sidecar) ───
OBJECT_STORAGE_LOCAL_MINIO_HOST=minio
OBJECT_STORAGE_LOCAL_MINIO_PORT=9000
OBJECT_STORAGE_LOCAL_MINIO_USERNAME=forge_app
OBJECT_STORAGE_LOCAL_MINIO_PASSWORD=#REPLACE_ME#
