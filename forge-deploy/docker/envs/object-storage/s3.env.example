# ------------------------------------------------------------------
# AWS S3 (or S3-compatible: Ceph, Cloudflare R2, etc.).
# Activate when OBJECT_STORAGE_TYPE=s3. Copy as s3.env.
# ------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=#REPLACE_ME#
OBJECT_STORAGE_ACCESS_KEY_SECRET=#REPLACE_ME#
# Use IAM-attached role / IRSA / pod identity instead of inline keys.
OBJECT_STORAGE_USE_MANAGED_IAM=false
