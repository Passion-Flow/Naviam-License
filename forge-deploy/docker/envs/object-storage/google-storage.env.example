# ------------------------------------------------------------------
# Google Cloud Storage. Activate when OBJECT_STORAGE_TYPE=google-storage.
# Copy as google-storage.env.
# ------------------------------------------------------------------
# Path inside the container to a mounted service account JSON file
# (volume-mount it into all three backend containers).
# Leave empty to use the metadata server / Workload Identity.
GOOGLE_APPLICATION_CREDENTIALS=
# Used to construct gs://<project>/<bucket>; usually equal to the GCP project id.
OBJECT_STORAGE_REGION=
