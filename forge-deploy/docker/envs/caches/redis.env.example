# ------------------------------------------------------------------
# Redis provider overrides. Activate only when CACHE_TYPE=redis.
# Copy as redis.env.
# ------------------------------------------------------------------
CACHE_PORT=6379
# Database index split — keep aligned with values.yaml / helm.
CACHE_DB_APP=0
CACHE_DB_SESSION=1
CACHE_DB_CELERY_BROKER=2
CACHE_DB_CELERY_RESULT=3
# Sentinel / Cluster mode (leave empty for standalone).
CACHE_SENTINEL_NODES=
CACHE_CLUSTER_NODES=
