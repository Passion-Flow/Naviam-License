# ------------------------------------------------------------------
# Essential defaults for Forge Docker Compose deployments.
# Only include variables required for services to start.
#
# For a default deployment, copy this file to .env and run:
#   docker compose up -d
#
# Optional and provider-specific variables live under docker/envs/.
# Copy an optional *.env.example file beside itself without the
# .example suffix when you need those advanced settings.
# Values in docker/.env take precedence over docker/envs/*.env files.
# ------------------------------------------------------------------

# Image registry and tag
IMAGE_REGISTRY=registry.your-company.com/forge
IMAGE_TAG=v0.1.0

# Entry ports (host-side)
HTTP_PORT=18080
HTTPS_PORT=18443

# Container-internal ports — keep aligned with forge-server settings.server_port
# and forge-admin nginx listen directive.
SERVER_PORT=13001
WEB_PORT=80

# TLS — true 时 nginx 容器额外挂载 admin-tls.conf.template 并 listen 443。
# 必须把证书放到 ../nginx/ssl/forge.crt + forge.key（与 nginx/templates/admin-tls.conf.template 对齐）。
NGINX_TLS_ENABLED=false

# Brand / front-end runtime
APP_API_BASE_URL=/api/v1
APP_SSO_ENABLED=false
APP_BRAND_PRIMARY_HSL=142 70% 49%

# Database (the database type support: postgres, mysql, oracle, tidb)
DATABASE_TYPE=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=forge_app
DATABASE_PASSWORD=#REPLACE_ME#
DATABASE_DATABASE=forge_main
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable

# Cache (the cache type support: redis)
CACHE_TYPE=redis
CACHE_HOST=redis
CACHE_PORT=6379
CACHE_USERNAME=
CACHE_PASSWORD=#REPLACE_ME#
CACHE_DB_APP=0
CACHE_DB_SESSION=1
CACHE_DB_CELERY_BROKER=2
CACHE_DB_CELERY_RESULT=3

# Object Storage (the storage type support: local, s3, azure-blob, aliyun-oss, google-storage, tencent-cos, volcengine-tos, huawei-obs)
OBJECT_STORAGE_TYPE=local
OBJECT_STORAGE_BUCKET_LICENSE_FILES=forge-license-files
OBJECT_STORAGE_BUCKET_PUBLIC_KEYS=forge-public-keys
OBJECT_STORAGE_BUCKET_AUDIT=forge-audit-snapshots

# Signing (the signing algorithm support: ed25519, rsa2048, rsa4096, sm2)
SIGNING_DEFAULT_ALGORITHM=ed25519
# The key storage backend support: local_file, object_storage, kms
KEY_STORAGE_BACKEND=local_file
KEY_STORAGE_LOCAL_PATH=/var/lib/forge/keys
# ⚠️ Losing this passphrase means losing every signing key. Back it up.
KEY_MASTER_PASSPHRASE=#REPLACE_ME#

# Admin session
AUTH_SESSION_SECRET=#REPLACE_ME#
AUTH_SESSION_MAX_AGE_SECONDS=604800

# Default super-admin (created once on first deploy by forge-bootstrap service).
# CHANGE these before going to production — the documented defaults are public.
BOOTSTRAP_ADMIN_USERNAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@forge.local
BOOTSTRAP_ADMIN_PASSWORD=#REPLACE_ME#

# Heartbeat / multi-env detection
HEARTBEAT_WINDOW_SECONDS=86400
HEARTBEAT_THRESHOLD=1
HEARTBEAT_GRACE_COUNT=0

# Logging (level support: debug, info, warning, error; format support: json, console)
LOG_LEVEL=info
LOG_FORMAT=json

# Replica counts (scheduler is forced to 1 by compose; do not override)
FORGE_WORKER_REPLICAS=1
