# Forge Server — 配置样例
#
# 复制为 .env 后填入本地值。.env 必须 gitignore。
# 字段名与 forge-deploy/docker/.env.example / forge-deploy/gitlab/variables.md /
# forge-deploy/helm/values.yaml 完全一致。
#
# HARD RULE：业务代码不直接读 os.environ，全部走 app.settings.get_settings()

# ─── Server ─────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=13001
SERVER_RELOAD=true
SERVER_LOG_LEVEL=debug

# ─── Database（字段化，禁止 DATABASE_URL）────────────────────
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=15432
DATABASE_USERNAME=forge_app
DATABASE_PASSWORD=Postgres@!QAZxsw2.
DATABASE_DATABASE=forge_main
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable

# ─── Cache (Redis) ──────────────────────────────────────────
CACHE_TYPE=redis
CACHE_HOST=localhost
CACHE_PORT=16379
CACHE_USERNAME=
CACHE_PASSWORD=Redis@!QAZxsw2.
CACHE_DB_APP=0
CACHE_DB_SESSION=1
CACHE_DB_CELERY_BROKER=2
CACHE_DB_CELERY_RESULT=3

# ─── Object Storage ─────────────────────────────────────────
# 可选：local | s3 | azure-blob | aliyun-oss | google-storage | tencent-cos | volcengine-tos | huawei-obs
OBJECT_STORAGE_TYPE=local

# local 模式：filesystem | minio
OBJECT_STORAGE_LOCAL_MODE=minio
OBJECT_STORAGE_LOCAL_PATH=
OBJECT_STORAGE_LOCAL_MINIO_HOST=localhost
OBJECT_STORAGE_LOCAL_MINIO_PORT=19000
OBJECT_STORAGE_LOCAL_MINIO_USERNAME=forge_app
OBJECT_STORAGE_LOCAL_MINIO_PASSWORD=Minio@!QAZxsw2.

# 公有云字段（用其它 provider 时填）
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_SECRET=

# Bucket 命名（client 用）
OBJECT_STORAGE_BUCKET_LICENSE_FILES=forge-license-files
OBJECT_STORAGE_BUCKET_PUBLIC_KEYS=forge-public-keys
OBJECT_STORAGE_BUCKET_AUDIT=forge-audit-snapshots

# ─── Signing / Key Storage ──────────────────────────────────
SIGNING_ALGORITHMS_ENABLED=["ed25519","rsa2048","sm2"]
SIGNING_DEFAULT_ALGORITHM=ed25519

KEY_STORAGE_BACKEND=local_file
KEY_STORAGE_LOCAL_PATH=./keys
KEY_MASTER_PASSPHRASE=  # ⚠️ 必填 / 高熵 / 绝不写日志

# ─── Auth ───────────────────────────────────────────────────
AUTH_SESSION_SECRET=   # ⚠️ 必填 / 高熵
AUTH_SESSION_MAX_AGE_SECONDS=604800
AUTH_SSO_ENABLED=false
AUTH_SSO_PROTOCOL=oauth2

# ─── Verifier API ───────────────────────────────────────────
VERIFIER_API_REQUIRE_MTLS=false
HEARTBEAT_DEFAULT_INTERVAL_SECONDS=86400

# ─── Logging ────────────────────────────────────────────────
LOG_FORMAT=json

# ─── External (默认全关，私有化按需打开) ────────────────────
TELEMETRY_ENABLED=false
ERROR_REPORTING_ENABLED=false
