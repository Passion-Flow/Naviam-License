package main

import (
	"fmt"
	"os"
	"time"

	forgeverifier "github.com/your-co/forge-verifier-go"
)

func main() {
	res, err := forgeverifier.Verify(os.Args[1], readKey(os.Args[2]), time.Date(2026, 6, 1, 0, 0, 0, 0, time.UTC))
	if err != nil {
		fmt.Println("ERROR:", err)
		os.Exit(1)
	}
	fmt.Printf("OK status=%s license_id=%s\n", res.Status, res.LicenseID)
}

func readKey(path string) []byte {
	b, err := os.ReadFile(path)
	if err != nil {
		panic(err)
	}
	return b
}
