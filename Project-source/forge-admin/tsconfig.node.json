{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild/node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
