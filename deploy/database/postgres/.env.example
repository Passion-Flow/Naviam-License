# Postgres 16 — License Console 主数据库
#
# 命名规范（与项目约定一致）：
#   - 类型/主机/端口/库名/用户名/密码 — 全部参数化，禁止 URL 拼接
#   - username = naviam_<project>     →  naviam_license
#   - database = naviam_<project>     →  naviam_license
#   - password = <Service>@!QAZxsw2.  →  Postgres@!QAZxsw2.
#
# ⚠️ 默认值仅用于本地开发；生产由 secrets 系统注入。

POSTGRES_TYPE=postgresql
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=naviam_license
POSTGRES_USERNAME=naviam_license
POSTGRES_PASSWORD=Postgres@!QAZxsw2.
