# Redis 7 — License Console 缓存 / 会话 / 限速
#
# 命名规范（与项目约定一致）：
#   - 类型/主机/端口/用户名/密码/DB — 全部参数化，禁止 URL 拼接
#   - username = naviam_<project>     →  naviam_license（Redis 6+ ACL）
#   - password = <Service>@!QAZxsw2.  →  Redis@!QAZxsw2.
#
# ⚠️ 默认值仅用于本地开发；生产由 secrets 系统注入。

REDIS_TYPE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=naviam_license
REDIS_PASSWORD=Redis@!QAZxsw2.
REDIS_DB=0
