# License Console — 项目级 .env.example
#
# 用法：
#   cp .env.example .env       # 仅本地开发；生产请走 secrets 管理
#   chmod 600 .env             # 防止其它用户读取
#
# 任何标 ⚠️ 的字段必须改成强随机；不得提交真实值到仓库。

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.dev
# ⚠️ 至少 50 字节随机；用 `python -c "import secrets; print(secrets.token_urlsafe(64))"`
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === Postgres（与 deploy/database/postgres/.env 对齐）===
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=license
POSTGRES_USER=license_app
# ⚠️ 与 deploy/database/postgres/.env 中的 POSTGRES_PASSWORD 一致
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_APP_PASSWORD

# === Redis（与 deploy/cache/redis/.env 对齐）===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# ⚠️
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# === Vendor 签名密钥（A 方案：age / sops 加密文件 + passphrase）===
# 路径指向 age 加密的私钥文件；运行期由 secrets 注入 passphrase 解密
SIGNING_KEY_BACKEND=file
SIGNING_KEY_PATH=/run/secrets/license_signing_key.age
# ⚠️ passphrase 用 secrets 系统注入；本地开发可临时写在 .env，但 .env 必须 0600
SIGNING_KEY_PASSPHRASE=CHANGE_ME_SIGNING_KEY_PASSPHRASE
# 当前活跃 kid；轮换后改这里
SIGNING_KEY_KID=v1-2026-04

# === Audit 签名密钥 ===
AUDIT_KEY_PATH=/run/secrets/audit_signing_key.age
AUDIT_KEY_PASSPHRASE=CHANGE_ME_AUDIT_KEY_PASSPHRASE
AUDIT_KEY_KID=audit-1

# === Session / CSRF（当前在代码中硬编码，预留）===
SESSION_COOKIE_NAME=license_sessionid
SESSION_COOKIE_AGE=43200            # 12h
CSRF_COOKIE_NAME=license_csrftoken

# === Default super-admin（仅首次启动 create_default_admin 用）===
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@workerspace.ai
# ⚠️ 默认值仅用于本地开发；生产部署必须改
ADMIN_PASSWORD=admin@workerspace.ai

# === SDK 公钥发布（可选）===
# 产品方需要的 vendor 公钥；运行期会落到 docs/sdk/public-key.pem 供下载
SDK_PUBKEY_OUTPUT_PATH=./build/sdk-pubkey.pem

# === Logging（预留）===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Online mode（V1 默认关闭；启用时配置）===
ONLINE_MODE_ENABLED=false
ONLINE_MTLS_CA_PATH=
ONLINE_MTLS_CERT_PATH=
ONLINE_MTLS_KEY_PATH=
