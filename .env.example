# License Console — 项目级 .env.example
#
# 用法：
#   cp .env.example .env       # 仅本地开发；生产请走 secrets 管理
#   chmod 600 .env             # 防止其它用户读取
#
# 命名规范（团队约定）：
#   - 用户名统一为 naviam_<project>          示例：naviam_license
#   - 数据库名统一为 naviam_<project>        示例：naviam_license
#   - 密码统一为 <Service>@!QAZxsw2.         首字母大写
#       Postgres@!QAZxsw2.   Redis@!QAZxsw2.
#       Elastic@!QAZxsw2.    Minio@!QAZxsw2.
#
# ⚠️ 任何标 ⚠️ 的字段在生产必须改成强随机；不得提交真实值到仓库。

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.dev
# ⚠️ 至少 50 字节随机；用 `python -c "import secrets; print(secrets.token_urlsafe(64))"`
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === Postgres（与 deploy/database/postgres/.env 对齐）===
POSTGRES_TYPE=postgresql
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=naviam_license
POSTGRES_USERNAME=naviam_license
# ⚠️ 默认值仅用于本地开发；生产由 secrets 系统注入
POSTGRES_PASSWORD=Postgres@!QAZxsw2.

# === Redis（与 deploy/cache/redis/.env 对齐）===
REDIS_TYPE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=naviam_license
# ⚠️ 默认值仅用于本地开发；生产由 secrets 系统注入
REDIS_PASSWORD=Redis@!QAZxsw2.
REDIS_DB=0

# === Elasticsearch（V2 引入；当前未启用）===
# ELASTIC_TYPE=elasticsearch
# ELASTIC_HOST=127.0.0.1
# ELASTIC_PORT=9200
# ELASTIC_USERNAME=naviam_license
# ELASTIC_PASSWORD=Elastic@!QAZxsw2.
# ELASTIC_INDEX_PREFIX=naviam_license

# === MinIO / S3（V2 引入；当前未启用）===
# MINIO_TYPE=minio
# MINIO_HOST=127.0.0.1
# MINIO_PORT=9000
# MINIO_USERNAME=naviam_license
# MINIO_PASSWORD=Minio@!QAZxsw2.
# MINIO_BUCKET=naviam-license

# === Vendor 签名密钥（A 方案：age / sops 加密文件 + passphrase）===
# 路径指向 age 加密的私钥文件；运行期由 secrets 注入 passphrase 解密
SIGNING_KEY_BACKEND=file
SIGNING_KEY_PATH=/run/secrets/license_signing_key.age
# ⚠️ passphrase 用 secrets 系统注入；本地开发可临时写在 .env，但 .env 必须 0600
SIGNING_KEY_PASSPHRASE=CHANGE_ME_SIGNING_KEY_PASSPHRASE
# 当前活跃 kid；轮换后改这里
SIGNING_KEY_KID=v1-2026-04

# === Audit 签名密钥 ===
AUDIT_KEY_PATH=/run/secrets/audit_signing_key.age
AUDIT_KEY_PASSPHRASE=CHANGE_ME_AUDIT_KEY_PASSPHRASE
AUDIT_KEY_KID=audit-1

# === Session / CSRF ===
SESSION_COOKIE_NAME=license_sessionid
SESSION_COOKIE_AGE=43200            # 12h
CSRF_COOKIE_NAME=license_csrftoken

# === Default super-admin（仅首次启动 create_default_admin 用）===
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@workerspace.ai
# ⚠️ 默认值仅用于本地开发；生产部署必须改 — startup 校验首次登录强制改密
ADMIN_PASSWORD=admin@workerspace.ai

# === SDK 公钥发布（可选）===
# 产品方需要的 vendor 公钥；运行期会落到 docs/sdk/public-key.pem 供下载
SDK_PUBKEY_OUTPUT_PATH=./build/sdk-pubkey.pem

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Online mode（V1 默认关闭；启用时配置）===
ONLINE_MODE_ENABLED=false
ONLINE_MTLS_CA_PATH=
ONLINE_MTLS_CERT_PATH=
ONLINE_MTLS_KEY_PATH=
